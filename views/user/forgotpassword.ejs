<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation - Forgot Password</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <link rel="stylesheet" href="/css/forgotpassword.css">
</head>

<body class="shared-bg">
    <main class="signup-container">
        <div class="signup-left">
            <div class="form-wrapper">
                <h1 class="title"><i class="fa-solid fa-lock" style="margin-right: 8px; font-size: 0.85em;"></i>Forgot password</h1>
                <p class="subtitle">Enter your email address</p>
                
                <form class="signup-form" id="forgotPasswordForm">
                    <div class="form-group">
                        <label for="email">Email</label>
                        <div class="input-container">
                            <i class="fa-regular fa-envelope input-icon"></i>
                            <input type="email" id="email" placeholder="Enter your email" required>
                        </div>
                    </div>

                    <div class="forgot-pwd" style="text-align: right; margin-bottom: 20px;">
                        <a href="/user/login" style="font-size: 13px; color: #666; text-decoration: none;">Back to login page</a>
                    </div>

                    <button type="submit" class="btn btn-login" id="submitBtn">Next</button>
                </form>
            </div>
        </div>

        <div class="signup-right">
            <div class="right-content">
                <h2 class="welcome-title">HomeStation</h2>
                <p class="welcome-desc">Your one stop destination for furniture, home furnishings, and decor to bring the joy.</p>
                <a href="/user/verify-otp" class="btn-secondary" style="text-decoration: none; display: inline-block;">Don't have an account? Sign up</a>
            </div>
        </div>
    </main>

    <script>
        document.getElementById('forgotPasswordForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const submitBtn = document.getElementById('submitBtn');
            
            // Loading state
            const originalText = submitBtn.innerText;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Checking...';
            submitBtn.disabled = true;

            try {
                const response = await fetch('/user/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });

                const data = await response.json();

                if (data.success) {
                    window.location.href = '/user/verify-otp';
                } else if (data.isExistingUser === false) {
                    Swal.fire({
                        icon: 'info',
                        title: 'Account Not Found',
                        text: data.message,
                        timer: 2500,
                        showConfirmButton: false,
                        heightAuto: false
                    }).then(() => {
                        window.location.href = '/user/register'; 
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: data.message,
                        confirmButtonColor: '#222',
                        heightAuto: false
                    });
                }
            } catch (error) {
                Swal.fire({ 
                    icon: 'error', 
                    title: 'Error', 
                    text: 'A network error occurred.', 
                    heightAuto: false 
                });
            } finally {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        });
    </script>
</body>
</html>