<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="icon" type="image/x-icon" href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <link rel="stylesheet" href="/css/user/forgotpassword.css">
</head>

<body class="shared-bg">
    <main class="signup-container">
        <input type="hidden" id="csrfToken" value="<%= csrfToken %>">
        <div class="signup-left">
            <div class="form-wrapper">
                <h1 class="title"><i class="fa-solid fa-lock header-icon-spacing"></i>Forgot password</h1>
                <p class="subtitle">Enter your email address</p>
                
                <form class="signup-form" id="forgotPasswordForm" novalidate>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <div class="input-container">
                            <i class="fa-regular fa-envelope input-icon"></i>
                            <input type="email" id="email" placeholder="Enter your email">
                        </div>
                    </div>

                    <div class="forgot-pwd forgot-pwd-align">
                        <a href="/user/login">Back to login page</a>
                    </div>

                    <button type="submit" class="btn btn-login" id="submitBtn">Next</button>
                </form>
            </div>
        </div>

        <div class="signup-right">
            <div class="right-content">
                <h2 class="welcome-title">HomeStation</h2>
                <p class="welcome-desc">Your one stop destination for furniture, home furnishings, and decor to bring the joy.</p>
                <a href="/user/register" class="btn-secondary text-decoration-none">Don't have an account? Sign up</a>
            </div>
        </div>
    </main>

    <script src="/js/user/forgotpassword.js"></script>
</body>
</html>