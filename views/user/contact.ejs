<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght=0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="icon" type="image/x-icon" href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <link rel="stylesheet" href="/css/user/contact.css">
</head>

<body>
    <input type="hidden" id="csrfToken" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

    <% if (typeof bannerText !== 'undefined' && bannerText) { %>
        <div class="promo-bar">
            <b><%- bannerText %></b>
        </div>
    <% } %>

    <header class="header">
        <div class="container-fluid header-container">
            <a href="/home" class="logo">HomeStation</a>
            <nav class="nav">
                <ul class="nav-list">
                    <li><a href="/home" class="nav-link">Home</a></li>
                    <li><a href="/products" class="nav-link">World of Mattress</a></li>
                    <li><a href="/deals" class="nav-link">Top Deals</a></li>
                    <li><a href="/bestsellers" class="nav-link">Best Sellers</a></li>
                    <li><a href="/contact" class="nav-link active">Contact Us</a></li>
                </ul>
            </nav>
            <div class="search-container">
                <input type="text" placeholder="Search for products..." id="searchInput">
                <button id="searchBtn" type="button"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
            <div class="header-actions">
                <a href="/user/wishlist" class="icon-link wishlist-link"><i class="fa-regular fa-heart"></i> Wishlist</a>
                <a href="/user/profile" class="icon-link"><i class="fa-regular fa-user"></i> Profile</a>
                <a href="/user/cart" class="icon-link"><i class="fa-solid fa-cart-shopping"></i> Cart</a>
            </div>
        </div>
    </header>

    <main class="contact-page">
        <section class="about-section">
            <div class="container">
                <h1 class="page-title">About HomeStation</h1>
                <div class="about-content">
                    <div class="about-text">
                        <p class="about-lead">Your premier destination for high-quality mattresses and sleep essentials, crafted to bring cloud-like comfort to every night.</p>
                        <p>Founded with the vision to make perfect sleep accessible to everyone, HomeStation engineers the finest quality mattresses. We believe that your bedroom should be a sanctuary of comfort and restoration.</p>
                        <p>Our team of sleep experts sources the finest memory foams, pocket coils, and organic materials to combine durability with exquisite comfort. From orthopedic support to plush luxury models, our diverse catalog is designed to help you wake up refreshed.</p>
                    </div>
                    <div class="about-image">
                        <img src="https://images.unsplash.com/photo-1505693314120-0d443867891c?auto=format&fit=crop&q=80&w=800" alt="Beautiful Bedroom With Mattress">
                    </div>
                </div>
            </div>
        </section>

        <section class="contact-section">
            <div class="container">
                <h2 class="section-title">Get In Touch</h2>
                <div class="contact-grid">
                    <div class="contact-info">
                        <h3>We'd Love to Hear From You</h3>
                        <p>Whether you have a question about our products, need assistance with your order, or just want to share some design ideas, our team is ready to answer all your questions.</p>

                        <div class="info-item">
                            <i class="fa-solid fa-location-dot"></i>
                            <div>
                                <h4>Visit Us</h4>
                                <p>123 Design Boulevard, Creative District<br>Innovation City, IN 400001</p>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="fa-solid fa-phone"></i>
                            <div>
                                <h4>Call Us</h4>
                                <p>+91 98765 43210<br>Mon-Fri, 9am to 6pm</p>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="fa-solid fa-envelope"></i>
                            <div>
                                <h4>Email Us</h4>
                                <p>support@homestation.xyz<br>hello@homestation.xyz</p>
                            </div>
                        </div>
                    </div>

                    <div class="contact-form-container">
                        <form class="contact-form" id="userContactInquiryForm" novalidate>
                            <div class="form-group">
                                <label for="name">Name</label>
                                <input type="text" id="name" placeholder="Your full name" 
                                       value="<%= isAuthenticated ? user.fullName : '' %>" 
                                       <%= isAuthenticated ? 'readonly' : '' %> class="<%= isAuthenticated ? 'locked-input' : '' %>">
                            </div>

                            <div class="form-group">
                                <label for="email">Email Address</label>
                                <input type="email" id="email" placeholder="john@example.com" 
                                       value="<%= isAuthenticated ? user.email : '' %>" 
                                       <%= isAuthenticated ? 'readonly' : '' %> class="<%= isAuthenticated ? 'locked-input' : '' %>">
                            </div>

                            <div class="form-group">
                                <label for="subject">Subject</label>
                                <select id="subject" class="subject-select">
                                    <option value="" disabled selected>Select a subject</option>
                                    <% if (typeof subjects !== 'undefined' && subjects.length > 0) { %>
                                        <% subjects.forEach(sub => { %>
                                            <option value="<%= sub._id %>"><%= sub.name %></option>
                                        <% }) %>
                                    <% } %>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="message">Message</label>
                                <textarea id="message" rows="5" placeholder="How can we help you?"></textarea>
                            </div>

                            <button type="submit" class="btn btn-submit">Send Message</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container-fluid footer-container">
            <div class="footer-left">
                <a href="/home" class="logo footer-logo">HomeStation</a>
                <p>Your premier destination for high-quality mattresses and sleep essentials, crafted to bring cloud-like comfort to every night.</p>
            </div>
            <div class="footer-links-wrapper">
                <div class="footer-column">
                    <h4>Shop</h4>
                    <ul>
                        <li><a href="/products">World of Mattress</a></li>
                        <li><a href="/deals">Top Deals</a></li>
                        <li><a href="/bestsellers">Best Sellers</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="#">Track Your Orders</a></li>
                        <li><a href="/privacy-policy">Privacy Policy</a></li>
                        <li><a href="/contact">Contact Us</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="container-fluid copyright">
            <p>&copy; 2026 HomeStation Store. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/user/contact.js"></script>
</body>
</html>