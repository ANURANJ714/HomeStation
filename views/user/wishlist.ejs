<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="icon" type="image/x-icon" href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <link rel="stylesheet" href="/css/user/wishlist.css">
</head>

<body class="shared-bg">
    <input type="hidden" id="csrfToken" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    
    <% if (typeof bannerText !== 'undefined' && bannerText) { %>
        <div class="promo-bar">
            <b><%- bannerText %></b>
        </div>
    <% } %>

    <header class="header">
        <div class="container-fluid header-container">
            <a href="/home" class="logo">HomeStation</a>
            <nav class="nav">
                <ul class="nav-list">
                    <li><a href="/home" class="nav-link">Home</a></li>
                    <li><a href="/products" class="nav-link">World of Mattress</a></li>
                    <li><a href="/deals" class="nav-link">Top Deals</a></li>
                    <li><a href="/bestsellers" class="nav-link">Best Sellers</a></li>
                    <li><a href="/contact" class="nav-link">Contact Us</a></li>
                </ul>
            </nav>

            <div class="search-container">
                <input type="text" placeholder="Search for products, brands and more..." id="searchInput">
                <button id="searchBtn" type="button"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>

            <div class="header-actions">
                <a href="/user/wishlist" class="icon-link wishlist-link active"><i class="fa-solid fa-heart"></i> Wishlist</a>
                <a href="/user/profile" class="icon-link"><i class="fa-solid fa-user"></i> Profile</a>
                <a href="/user/cart" class="icon-link"><i class="fa-solid fa-cart-shopping"></i> Cart</a>
            </div>
        </div>
    </header>

    <section class="profile-section">
        <div class="container profile-layout">
            <aside class="profile-sidebar" id="appSidebar">
                <div class="profile-user-info">
                    <img src="<%= user.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_1280.png' %>" alt="Profile Image" class="sidebar-avatar">
                    <div class="user-greeting">
                        <span class="hello-text">Hello,</span>
                        <span class="user-name"><%= user.fullName || 'User' %></span>
                    </div>
                </div>
                <hr class="sidebar-divider">
                <div class="sidebar-menu">
                    <h3>Account Settings</h3>
                    <ul>
                        <li><a href="/user/profile">Profile information</a></li>
                        <li><a href="/user/addresses">Manage addresses</a></li>
                    </ul>
                    <hr class="sidebar-divider">
                    <h3>My Stuffs</h3>
                    <ul>
                        <li><a href="/user/orders">My Orders</a></li>
                        <li><a href="/user/wishlist" class="active">My Wishlists</a></li>
                        <li><a href="/user/wallet">My Wallet</a></li>
                        <li><a href="/user/coupons">Coupons Available</a></li>
                    </ul>
                    <hr class="sidebar-divider">
                    <div class="logout-wrapper">
                        <form action="/user/logout" method="POST" id="logoutForm" class="m-0">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="logout-link">
                                <i class="fa-solid fa-power-off"></i> Logout
                            </button>
                        </form>
                    </div>
                </div>
            </aside>

            <main class="profile-content">
                <div class="wishlist-header">
                    <h1 class="wishlist-title">My Wishlist (<%= totalItems %> Items)</h1>
                </div>

                <div class="wishlist-grid" id="wishlistGrid">
                    <% if (items && items.length > 0) { %>
                        <% items.forEach(item => { 
                            const product = item.productId;
                            const currentPrice = Math.round(item.originalPrice * (1 - (item.discount || 0) / 100));
                        %>
                        <div class="wishlist-item" data-variant-id="<%= item._id %>">
                            <div class="item-img-container">
                                <img src="<%= product.images && product.images[0] ? product.images[0] : 'https://placehold.co/300' %>" alt="<%= product.name %>">
                            </div>
                            <div class="item-info">
                                <h2 class="item-name"><%= product.name %> (<%= item.variantName %>)</h2>
                                <div class="price-container">
                                    <p class="item-price">₹<%= currentPrice.toLocaleString('en-IN') %></p>
                                    <% if (item.discount > 0) { %>
                                        <p class="original-price">₹<%= item.originalPrice.toLocaleString('en-IN') %></p>
                                        <span class="discount-off">(<%= item.discount %>% OFF)</span>
                                    <% } %>
                                </div>
                                <div class="item-actions">
                                    <button type="button" class="btn-add-cart add-to-cart-btn" data-variant-id="<%= item._id %>">Add to Cart</button>
                                    <button type="button" class="btn-delete trigger-delete-btn" data-variant-id="<%= item._id %>" data-name="<%= product.name %>">
                                        <i class="fa-regular fa-trash-can"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    <% } else { %>
                        <p style="color: #666; grid-column: 1 / -1;">Your wishlist is currently empty. Start adding some products!</p>
                    <% } %>
                </div>

                <% if (totalPages >= 1) { %>
                    <div class="pagination">
                        <% if (currentPage > 1) { %>
                            <a href="?page=<%= currentPage - 1 %>" class="page-link"><i class="fa-solid fa-chevron-left"></i></a>
                        <% } %>
                        
                        <% for (let i = 1; i <= totalPages; i++) { %>
                            <a href="?page=<%= i %>" class="page-link <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                        <% } %>
                        
                        <% if (currentPage < totalPages) { %>
                            <a href="?page=<%= currentPage + 1 %>" class="page-link"><i class="fa-solid fa-chevron-right"></i></a>
                        <% } %>
                    </div>
                <% } %>
            </main>
        </div>
    </section>

    <div class="modal-overlay" id="deleteModal">
        <div class="confirm-modal">
            <div class="modal-header-box">
                <i class="fa-solid fa-triangle-exclamation modal-icon"></i>
                <h2>Remove from Wishlist?</h2>
            </div>
            <p class="modal-text">Are you sure you want to remove <strong id="deleteItemName">Item Name</strong> from your wishlist?</p>
            <div class="modal-actions">
                <button type="button" class="btn-modal-cancel" id="cancelDeleteBtn">Cancel</button>
                <button type="button" class="btn-modal-confirm" id="confirmDeleteBtn">Yes, Remove</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="cartSuccessModal">
        <div class="confirm-modal success-modal">
            <div class="modal-header-box">
                <i class="fa-solid fa-circle-check modal-icon success"></i>
                <h2>Added to Cart!</h2>
            </div>
            <p class="modal-text">Item has been successfully added to your shopping cart.</p>
            <div class="modal-actions">
                <button type="button" class="btn-modal-cancel" id="closeCartSuccessBtn">Continue Shopping</button>
                <a href="/cart" class="btn-modal-confirm success-btn">View Cart</a>
            </div>
        </div>
    </div>

    <script src="/js/user/wishlist.js"></script>
</body>
</html>