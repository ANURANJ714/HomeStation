<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="icon" type="image/x-icon" href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <link rel="stylesheet" href="/css/user/verify-otp.css">
</head>

<body class="shared-bg">
    <main class="signup-container">
        
        <input type="hidden" id="csrfToken" value="<%= csrfToken %>">

        <div class="signup-left">
            <div class="form-wrapper">
                <h1 class="title"><i class="fa-solid fa-shield-halved security-title-icon"></i>Verify OTP</h1>
                <p class="subtitle">Enter the 6-digit code sent to <strong><%= email %></strong>.</p>

                <form class="signup-form" id="otpForm" novalidate>

                    <input type="hidden" name="enteredOtp" id="combinedOtp">

                    <div class="otp-container">
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric" autofocus>
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric">
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric">
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric">
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric">
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric">
                    </div>

                    <div class="timer-text" id="timerContainer">
                        <span id="timer">60</span>s remaining
                    </div>

                    <button type="submit" class="btn btn-login" id="submitBtn">Verify OTP</button>
                </root>
            </div>
        </div>

        <div class="signup-right">
            <div class="right-content">
                <h2 class="welcome-title">HomeStation</h2>
                <p class="welcome-desc">Your one stop destination for furniture, home furnishings, and decor to bring the joy.</p>
            </div>
        </div>
    </main>

    <script src="/js/user/verify-otp.js"></script>
</body>

</html>