<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="icon" type="image/x-icon"
        href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <link rel="stylesheet" href="/css/user/addresses.css">
</head>

<body class="shared-bg">
    <% if (typeof bannerText !=='undefined' && bannerText) { %>
        <div class="promo-bar">
            <b><%- bannerText %></b>
        </div>
        <% } %>

            <header class="header">
                <div class="container-fluid header-container">
                    <a href="/home" class="logo">HomeStation</a>
                    <nav class="nav">
                        <ul class="nav-list">
                            <li><a href="/home" class="nav-link">Home</a></li>
                            <li><a href="/products" class="nav-link">World of Mattress</a></li>
                            <li><a href="/deals" class="nav-link">Top Deals</a></li>
                            <li><a href="/bestsellers" class="nav-link">Best Sellers</a></li>
                            <li><a href="/contact" class="nav-link">Contact Us</a></li>
                        </ul>
                    </nav>
                    <div class="search-container">
                        <input type="text" placeholder="Search for products, brands and more..." id="searchInput">
                        <button id="searchBtn" type="button"><i class="fa-solid fa-magnifying-glass"></i></button>
                    </div>
                    <div class="header-actions">
                        <a href="/user/wishlist" class="icon-link wishlist-link"><i class="fa-regular fa-heart"></i>
                            Wishlist</a>
                        <a href="/user/profile" class="icon-link"><i class="fa-solid fa-user"></i> Profile</a>
                        <a href="/cart" class="icon-link"><i class="fa-solid fa-cart-shopping"></i> Cart</a>
                    </div>
                </div>
            </header>

            <section class="profile-section">
                <div class="container profile-layout">

                    <aside class="profile-sidebar" id="appSidebar">
                        <div class="profile-user-info">
                            <img src="<%= user.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_1280.png' %>"
                                alt="Profile" class="sidebar-avatar">
                            <div class="user-greeting">
                                <span class="hello-text">Hello,</span>
                                <span class="user-name" id="sidebarName">
                                    <%= user.fullName || 'User' %>
                                </span>
                            </div>
                        </div>

                        <hr class="sidebar-divider">
                        <div class="sidebar-menu">
                            <h3>Account Settings</h3>
                            <ul>
                                <li><a href="/user/profile">Profile information</a></li>
                                <li><a href="/user/addresses" class="active">Manage addresses</a></li>
                            </ul>
                            <hr class="sidebar-divider">
                            <h3>My Stuffs</h3>
                            <ul>
                                <li><a href="/user/orders">My Orders</a></li>
                                <li><a href="/user/wishlist">My Wishlists</a></li>
                                <li><a href="/user/wallet">My Wallet</a></li>
                                <li><a href="/user/coupons">Coupons Available</a></li>
                            </ul>
                            <hr class="sidebar-divider">

                            <div class="logout-wrapper">
                                <form action="/user/logout" method="POST" id="logoutForm" class="m-0">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="logout-link">
                                        <i class="fa-solid fa-power-off"></i> Logout
                                    </button>
                                </form>
                            </div>
                        </div>
                    </aside>

                    <main class="profile-content">
                        <input type="hidden" id="csrfToken" value="<%= csrfToken %>">

                        <div class="addresses-header">
                            <h2 class="edit-profile-title">Manage your addresses</h2>
                            <button class="btn-add-address" id="addAddressBtn">
                                <i class="fa-solid fa-plus"></i> ADD ADDRESS
                            </button>
                        </div>

                        <div class="address-list">
                            <% if (addresses && addresses.length> 0) { %>
                                <% addresses.forEach(address=> { %>
                                    <div class="address-card">
                                        <div class="address-card-header">
                                            <span class="address-type-badge <%= address.addressType.toLowerCase() %>">
                                                <% if(address.addressType==='Home' ) { %> <i
                                                        class="fa-solid fa-house"></i>
                                                    <% } else if(address.addressType==='Work' ) { %> <i
                                                            class="fa-solid fa-briefcase"></i>
                                                        <% } else { %> <i class="fa-solid fa-location-dot"></i>
                                                            <% } %>
                                                                <%= address.addressType %>
                                                                    <% if(address.isDefault) { %> (Default) <% } %>
                                            </span>
                                            <div class="address-menu-wrapper">
                                                <button class="card-hamburger-trigger" title="Options">
                                                    <i class="fa-solid fa-ellipsis-vertical"></i>
                                                </button>
                                                <div class="address-dropdown">
                                                    <button class="dropdown-item action-edit"
                                                        data-id="<%= address._id %>"
                                                        data-type="<%= address.addressType %>"
                                                        data-name="<%= address.name %>"
                                                        data-phone="<%= address.phone %>"
                                                        data-address="<%= address.fullAddress %>"
                                                        data-city="<%= address.city %>"
                                                        data-state="<%= address.state %>"
                                                        data-pincode="<%= address.pincode %>"
                                                        data-default="<%= address.isDefault %>">
                                                        <i class="fa-solid fa-pen"></i> Edit
                                                    </button>
                                                    <button class="dropdown-item delete action-delete"
                                                        data-id="<%= address._id %>">
                                                        <i class="fa-solid fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="address-card-body">
                                            <p class="address-name">
                                                <%= address.name %>
                                            </p>
                                            <p class="address-line">
                                                <%= address.fullAddress %>
                                            </p>
                                            <p class="address-line">
                                                <%= address.city %>, <%= address.state %> - <%= address.pincode %>
                                            </p>
                                            <p class="address-phone"><i class="fa-solid fa-phone"></i>
                                                <%= address.phone %>
                                            </p>
                                        </div>
                                    </div>
                                    <% }); %>
                                        <% } else { %>
                                            <p class="no-address-fallback-text">No addresses found. Add one to get
                                                started!</p>
                                            <% } %>
                        </div>
                        <% if (addresses && addresses.length> 0) { %>
                            <div class="pagination-wrapper">
                                <ul class="pagination-list">
                                    <% if (currentPage> 1) { %>
                                        <li>
                                            <a href="/user/addresses?page=<%= currentPage - 1 %>" class="page-link">
                                                <i class="fa-solid fa-chevron-left"></i> Prev
                                            </a>
                                        </li>
                                        <% } else { %>
                                            <li>
                                                <span class="page-link disabled">
                                                    <i class="fa-solid fa-chevron-left"></i> Prev
                                                </span>
                                            </li>
                                            <% } %>

                                                <% for(let i=1; i <=totalPages; i++) { %>
                                                    <li>
                                                        <a href="/user/addresses?page=<%= i %>"
                                                            class="page-link <%= currentPage === i ? 'active' : '' %>">
                                                            <%= i %>
                                                        </a>
                                                    </li>
                                                    <% } %>

                                                        <% if (currentPage < totalPages) { %>
                                                            <li>
                                                                <a href="/user/addresses?page=<%= currentPage + 1 %>"
                                                                    class="page-link">
                                                                    Next <i class="fa-solid fa-chevron-right"></i>
                                                                </a>
                                                            </li>
                                                            <% } else { %>
                                                                <li>
                                                                    <span class="page-link disabled">
                                                                        Next <i class="fa-solid fa-chevron-right"></i>
                                                                    </span>
                                                                </li>
                                                                <% } %>
                                </ul>
                            </div>
                            <% } %>
                    </main>
                </div>
            </section>

            <div class="modal-overlay" id="addAddressModal">
                <div class="modal-box">
                    <div class="modal-header">
                        <h3 id="modalTitle">Add New Address</h3>
                        <button type="button" class="modal-close" data-close="addAddressModal"><i
                                class="fa-solid fa-xmark"></i></button>
                    </div>
                    <div class="modal-body">
                        <form id="addressForm" novalidate>
                            <input type="hidden" id="fieldId">
                            <div class="address-type-selector">
                                <label class="type-option">
                                    <input type="radio" name="addr-type" id="typeHome" value="Home" checked>
                                    <span><i class="fa-solid fa-house"></i> Home</span>
                                </label>
                                <label class="type-option">
                                    <input type="radio" name="addr-type" id="typeWork" value="Work">
                                    <span><i class="fa-solid fa-briefcase"></i> Work</span>
                                </label>
                                <label class="type-option">
                                    <input type="radio" name="addr-type" id="typeOther" value="Other">
                                    <span><i class="fa-solid fa-location-dot"></i> Other</span>
                                </label>
                            </div>
                            <div class="modal-form">
                                <div class="modal-form-row">
                                    <div class="modal-form-col">
                                        <label for="fieldName">Full Name</label>
                                        <input type="text" id="fieldName" placeholder="Enter full name"
                                            class="form-control">
                                    </div>
                                    <div class="modal-form-col">
                                        <label for="fieldPhone">Phone Number</label>
                                        <input type="text" id="fieldPhone" inputmode="numeric" maxlength="10"
                                            placeholder="10-digit number" class="form-control">
                                    </div>
                                </div>
                                <div class="modal-form-row">
                                    <div class="modal-form-col">
                                        <label for="fieldPincode">Pincode</label>
                                        <input type="text" id="fieldPincode" inputmode="numeric" maxlength="6"
                                            placeholder="Enter pincode" class="form-control">
                                    </div>
                                    <div class="modal-form-col">
                                        <label for="fieldCity">City</label>
                                        <input type="text" id="fieldCity" placeholder="Enter city" class="form-control">
                                    </div>
                                </div>
                                <div class="modal-form-row">
                                    <div class="modal-form-col">
                                        <label for="fieldState">State</label>
                                        <input type="text" id="fieldState" placeholder="Enter state"
                                            class="form-control">
                                    </div>
                                </div>
                                <div class="modal-form-row">
                                    <div class="modal-form-col full-width-col">
                                        <label for="fieldAddress">Address (House No., Street, Area)</label>
                                        <textarea id="fieldAddress" placeholder="Enter full address"
                                            class="form-control" rows="3"></textarea>
                                    </div>
                                </div>
                                <div class="modal-form-row checkbox-row">
                                    <label class="checkbox-container">
                                        <input type="checkbox" id="fieldDefault">
                                        <span class="checkbox-checkmark"></span>
                                        Set as default address
                                    </label>
                                </div>
                                <div class="modal-actions">
                                    <button type="button" class="btn-cancel-gray"
                                        data-close="addAddressModal">Cancel</button>
                                    <button type="submit" class="btn-save" id="modalSaveBtn">Save Address</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="modal-overlay" id="deleteConfirmModal">
                <div class="modal-box modal-box-sm">
                    <div class="modal-header">
                        <h3 class="delete-modal-title"><i class="fa-solid fa-triangle-exclamation"></i> Delete Address
                        </h3>
                        <button type="button" class="modal-close" data-close="deleteConfirmModal"><i
                                class="fa-solid fa-xmark"></i></button>
                    </div>
                    <div class="modal-body">
                        <p class="delete-confirm-text">Are you sure you want to delete this address?</p>
                        <div class="modal-actions">
                            <button type="button" class="btn-cancel-gray"
                                data-close="deleteConfirmModal">Cancel</button>
                            <button type="button" class="btn-delete-confirm" id="modalDeleteBtn"><i
                                    class="fa-solid fa-trash"></i> Yes, Delete</button>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="footer">
                <div class="container-fluid footer-container">
                    <div class="footer-left">
                        <a href="/home" class="logo footer-logo">HomeStation</a>
                        <p>Your premier destination for high-quality mattresses and sleep essentials, crafted to bring
                            cloud-like comfort to every night.</p>
                    </div>
                    <div class="footer-links-wrapper">
                        <div class="footer-column">
                            <h4>Shop</h4>
                            <ul>
                                <li><a href="/products">World of Mattress</a></li>
                                <li><a href="/deals">Top Deals</a></li>
                                <li><a href="/bestsellers">Best Sellers</a></li>
                            </ul>
                        </div>
                        <div class="footer-column">
                            <h4>Support</h4>
                            <ul>
                                <li><a href="/user/orders">Track Your Orders</a></li>
                                <li><a href="/privacy-policy">Privacy Policy</a></li>
                                <li><a href="/contact">Contact Us</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="container-fluid copyright">
                    <p>&copy; 2026 HomeStation Store. All rights reserved.</p>
                </div>
            </footer>

            <script src="/js/user/addresses.js"></script>
</body>

</html>