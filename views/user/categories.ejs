<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Mattresses - HomeStation</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght=400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght=0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/user/categories.css">
</head>

<body>
    <% if (typeof bannerText !== 'undefined' && bannerText !== '') { %>
        <div class="promo-bar">
            <strong><%= bannerText %></strong>
        </div>
    <% } %>

    <header class="header">
        <div class="container-fluid header-container">
            <div class="mobile-toggle" id="mobileToggle">
                <i class="fa-solid fa-bars"></i>
            </div>
            <a href="/home" class="logo">HomeStation</a>
            <nav class="nav" id="navMenu">
                <ul class="nav-list">
                    <li><a href="/home" class="nav-link">Home</a></li>
                    <li><a href="/admin/products" class="nav-link active">World of Mattress</a></li>
                    <li><a href="/deals" class="nav-link">Top Deals</a></li>
                    <li><a href="/bestsellers" class="nav-link">Best Sellers</a></li>
                    <li><a href="/contact" class="nav-link">Contact Us</a></li>
                </ul>
            </nav>
            
            <form id="searchForm" action="/admin/products" method="GET" class="search-container" style="margin: 0;">
                <input type="hidden" name="category" value="<%= categoryFilter %>">
                <input type="hidden" name="price" value="<%= maxPriceFilter || '' %>">
                <input type="text" name="search" placeholder="Search for products, brands and more..." id="searchInput" value="<%= searchQuery %>">
                <button type="submit" id="searchBtn"><i class="fa-solid fa-magnifying-glass"></i></button>
            </form>

            <div class="header-actions">
                <a href="/wishlist" class="icon-link wishlist-link"><i class="fa-regular fa-heart"></i> <span class="action-text">Wishlist</span></a>
                
                <% if (user) { %>
                    <a href="/user/profile" class="icon-link"><i class="fa-regular fa-user"></i> <span class="action-text">Profile</span></a>
                <% } else { %>
                    <a href="/user/login" class="icon-link"><i class="fa-solid fa-arrow-right-to-bracket"></i> <span class="action-text">Login</span></a>
                <% } %>
                
                <a href="/cart" class="icon-link"><i class="fa-solid fa-cart-shopping"></i> <span class="action-text">Cart</span></a>
            </div>
        </div>
    </header>

    <main class="furniture-page">
        <div class="container furniture-container">
            
            <aside class="sidebar">
                <div class="filter-group">
                    <h3>Categories</h3>
                    <ul class="filter-list" id="categoryFilterList">
                        <li>
                            <a href="/admin/products?status=<%= typeof statusFilter !== 'undefined' ? statusFilter : 'all' %>" class="<%= !categoryFilter ? 'active' : '' %>">All Mattresses</a>
                        </li>
                        <% categories.forEach(cat => { %>
                            <li>
                                <a href="/admin/products?category=<%= cat._id %>&status=<%= typeof statusFilter !== 'undefined' ? statusFilter : 'all' %>&search=<%= searchQuery %>" 
                                   class="<%= categoryFilter === cat._id.toString() ? 'active' : '' %>">
                                   <%= cat.name %>
                                </a>
                            </li>
                        <% }) %>
                    </ul>
                </div>

                <div class="filter-group">
                    <h3>Filter by Price</h3>
                    <form id="priceFilterForm" action="/admin/products" method="GET">
                        <input type="hidden" name="search" value="<%= searchQuery %>">
                        <input type="hidden" name="category" value="<%= categoryFilter %>">
                        <div class="price-range-slider">
                            <input type="range" name="price" min="0" max="150000" value="<%= maxPriceFilter || 150000 %>" class="slider" id="priceRange">
                            <div class="price-labels">
                                <span>Hex ₹0</span>
                                <span id="priceValue">₹<%= (maxPriceFilter || 150000).toLocaleString('en-IN') %></span>
                                <span>₹1.5L+</span>
                            </div>
                        </div>
                    </form>
                </div>
            </aside>

            <section class="main-content">
                <div class="page-header">
                    <h2>All Mattresses</h2>
                </div>

                <div class="products-grid">
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <div class="product-card">
                                <div class="product-image">
                                    <img src="<%= product.images && product.images.length > 0 ? product.images[0] : 'https://placehold.co/400x330?text=No+Image' %>" alt="<%= product.name %>">
                                    <% if (product.discount > 15) { %>
                                        <span class="badge">Best Seller</span>
                                    <% } %>
                                    <button class="wishlist-btn" data-product-id="<%= product._id %>"><i class="fa-regular fa-heart"></i></button>
                                </div>
                                <div class="product-info">
                                    <h3><%= product.name %></h3>
                                    <div class="stars"><i class="fa-solid fa-star"></i> 4.8 (95)</div>
                                    <div class="card-footer">
                                        <div class="price-block" style="display: flex; flex-direction: column; gap: 2px;">
                                            <span class="price" style="font-size: 20px; font-weight: 700; color: #000;">₹<%= Math.round(product.currentPrice).toLocaleString('en-IN') %></span>
                                            <% if (product.discount > 0) { %>
                                                <div style="display: flex; gap: 8px; align-items: center; font-size: 13px;">
                                                    <span style="text-decoration: line-through; color: #888;">Fixed ₹<%= product.originalPrice.toLocaleString('en-IN') %></span>
                                                    <span style="color: #4CAF50; font-weight: 600;"><%= product.discount %>% OFF</span>
                                                </div>
                                            <% } %>
                                        </div>
                                        <button class="add-to-cart-btn" data-product-id="<%= product._id %>"><i class="fa-solid fa-cart-plus"></i> Add</button>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div style="grid-column: 1 / -1; text-align: center; padding: 80px 20px; background: #fff; border-radius: 12px; border: 1px solid #eee;">
                            <i class="fa-solid fa-box-open" style="font-size: 48px; color: #ccc; margin-bottom: 15px; display: block;"></i>
                            <h3 style="font-size: 20px; margin-bottom: 8px; color: #222;">No products found</h3>
                            <p style="color: #666; font-size: 14px;">Try shifting your target metrics constraint slider higher or sorting by a clear baseline query parameter block choice.</p>
                        </div>
                    <% } %>
                </div>

                <% if (totalPages > 1) { %>
                    <div class="pagination">
                        <% let baseParams = `?search=${searchQuery}&category=${categoryFilter}&price=${maxPriceFilter || ''}&page=` %>
                        
                        <% if (currentPage > 1) { %>
                            <a href="<%= baseParams %><%= currentPage - 1 %>" class="page-btn" style="text-decoration: none;"><i class="fa-solid fa-chevron-left"></i> Previous</a>
                        <% } %>

                        <div class="page-numbers">
                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <a href="<%= baseParams %><%= i %>" class="page-num <%= currentPage === i ? 'active' : '' %>" style="text-decoration: none;"><%= i %></a>
                            <% } %>
                        </div>

                        <% if (currentPage < totalPages) { %>
                            <a href="<%= baseParams %><%= currentPage + 1 %>" class="page-btn" style="text-decoration: none;">Next <i class="fa-solid fa-chevron-right"></i></a>
                        <% } %>
                    </div>
                <% } %>
            </section>
        </div>
    </main>

    <footer class="footer">
        <div class="container-fluid footer-container">
            <div class="footer-left">
                <a href="/home" class="logo footer-logo">HomeStation</a>
                <p>Your premier destination for high-quality mattresses and sleep essentials, crafted to bring cloud-like comfort to every night.</p>
            </div>
            <div class="footer-links-wrapper">
                <div class="footer-column">
                    <h4>Shop</h4>
                    <ul>
                        <li><a href="/admin/products">World of Mattress</a></li>
                        <li><a href="/deals">Top Deals</a></li>
                        <li><a href="/bestsellers">Best Sellers</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="/orders/track">Track Your Orders</a></li>
                        <li><a href="/privacy">Privacy Policy</a></li>
                        <li><a href="/contact">Contact Us</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="container-fluid copyright">
            <p>&copy; 2026 HomeStation Store. All rights reserved.</p>
        </div>
    </footer>

    <div id="toast" class="toast">
        <i class="fa-solid fa-circle-check"></i>
        <span id="toast-message">Operation successful</span>
    </div>

    <input type="hidden" id="globalCsrf" value="<%= csrfToken %>">

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const csrfToken = document.getElementById('globalCsrf').value;
            const slider = document.getElementById('priceRange');
            const priceValue = document.getElementById('priceValue');
            const priceForm = document.getElementById('priceFilterForm');

            function showToast(message) {
                const toast = document.getElementById('toast');
                const toastMessage = document.getElementById('toast-message');
                toastMessage.textContent = message;
                toast.classList.add('show');
                setTimeout(() => { toast.classList.remove('show'); }, 3000);
            }

            if (slider) {
                let timeout = null;
                slider.addEventListener('input', function () {
                    priceValue.textContent = "₹" + parseInt(this.value).toLocaleString('en-IN');
                    
                    clearTimeout(timeout);
                    timeout = setTimeout(() => {
                        priceForm.submit();
                    }, 500); 
                });
            }

            document.body.addEventListener('click', async (e) => {
                const cartBtn = e.target.closest('.add-to-cart-btn');
                const wishlistBtn = e.target.closest('.wishlist-btn');
                const mobileToggle = e.target.closest('#mobileToggle');

                if (mobileToggle) {
                    const navMenu = document.getElementById('navMenu');
                    navMenu.classList.toggle('active');
                    const icon = mobileToggle.querySelector('i');
                    icon.classList.toggle('fa-bars');
                    icon.classList.toggle('fa-xmark');
                }

                if (cartBtn) {
                    e.preventDefault();
                    const itemId = cartBtn.getAttribute('data-product-id');
                    showToast('Item added to cart successfully!');
                }

                if (wishlistBtn) {
                    e.preventDefault();
                    wishlistBtn.classList.toggle('liked');
                    const icon = wishlistBtn.querySelector('i');
                    icon.classList.toggle('fa-regular');
                    icon.classList.toggle('fa-solid');
                    showToast(wishlistBtn.classList.contains('liked') ? 'Item added to wishlist!' : 'Item removed from wishlist!');
                }
            });
        });
    </script>
</body>

</html>