<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght=0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="icon" type="image/x-icon" href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <link rel="stylesheet" href="/css/user/home.css">
    <link rel="stylesheet" href="/css/user/categories.css">
</head>

<body>
    <input type="hidden" id="csrfToken" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <input type="hidden" id="currentCategoryFilter" value="<%= currentCategory %>">
    <input type="hidden" id="serverAlertStatus" value="<%= typeof errorAlert !== 'undefined' && errorAlert ? errorAlert.type : '' %>">
    <input type="hidden" id="serverAlertTitle" value="<%= typeof errorAlert !== 'undefined' && errorAlert ? errorAlert.title : '' %>">
    <input type="hidden" id="serverAlertMessage" value="<%= typeof errorAlert !== 'undefined' && errorAlert ? errorAlert.message : '' %>">

    <% if (typeof bannerText !== 'undefined' && bannerText) { %>
        <div class="promo-bar">
            <b><%- bannerText %></b>
        </div>
    <% } %>

    <header class="header">
        <div class="container-fluid header-container">
            <div class="header-left-group">
                <a href="/home" class="logo">HomeStation</a>
            </div>

            <nav class="nav" id="appNavbar">
                <ul class="nav-list">
                    <li><a href="/home" class="nav-link">Home</a></li>
                    <li><a href="/products" class="nav-link active">World of Mattress</a></li>
                    <li><a href="/deals" class="nav-link">Top Deals</a></li>
                    <li><a href="/bestsellers" class="nav-link">Best Sellers</a></li>
                    <li><a href="/contact" class="nav-link">Contact Us</a></li>
                </ul>
            </nav>

            <div class="search-container">
                <input type="text" placeholder="Search for products, brands and more..." id="searchInput" value="<%= searchQuery %>">
                <button id="searchBtn" type="button"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>

            <div class="header-actions">
                <a href="/user/wishlist" class="icon-link wishlist-link"><i class="fa-regular fa-heart"></i> <span class="action-text">Wishlist</span></a>
                <% if (user) { %>
                    <a href="/user/profile" class="icon-link"><i class="fa-solid fa-user"></i> <span class="action-text">Profile</span></a>
                <% } else { %>
                    <a href="/user/login" class="icon-link"><i class="fa-solid fa-right-to-bracket"></i> <span class="action-text">Login</span></a>
                <% } %>
                <a href="/user/cart" class="icon-link"><i class="fa-solid fa-cart-shopping"></i> <span class="action-text">Cart</span></a>
            </div>
        </div>
    </header>

    <main class="mattress-page">
        <div class="container-fluid mattress-container">
            <aside class="sidebar">
                <div class="filter-group">
                    <h3>Categories</h3>
                    <ul class="filter-list" id="categoryFilterList">
                        <li>
                            <a href="/products?category=all" class="cat-filter-item <%= currentCategory === 'all' ? 'active' : '' %>" data-category="all">
                                All Mattresses
                            </a>
                        </li>
                        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                            <% categories.forEach(cat => { %>
                                <li>
                                    <a href="/products?category=<%= cat._id %>" class="cat-filter-item <%= currentCategory === cat._id.toString() ? 'active' : '' %>" data-category="<%= cat._id %>">
                                        <%= cat.name %>
                                    </a>
                                </li>
                            <% }) %>
                        <% } %>
                    </ul>
                </div>

                <div class="filter-group">
                    <h3>Filter by Brand</h3>
                    <ul class="filter-list checkbox-list" id="brandFilterList">
                        <% if (typeof brands !== 'undefined' && brands.length > 0) { %>
                            <% brands.forEach(brand => { %>
                                <% const isChecked = currentBrands.includes(brand); %>
                                <li>
                                    <label>
                                        <input type="checkbox" class="brand-checkbox" value="<%= brand %>" <%= isChecked ? 'checked' : '' %>> 
                                        <%= brand %>
                                    </label>
                                </li>
                            <% }) %>
                        <% } %>
                    </ul>
                </div>
            </aside>

            <section class="main-content">
                <div class="page-header">
                    <h2><%= pageHeading %></h2>
                    <div class="filter-dropdown">
                        <label for="priceSort">Sort by Price</label>
                        <select id="priceSort" class="sort-select">
                            <option value="all" <%= currentSort === 'all' ? 'selected' : '' %>>All Price Range</option>
                            <option value="highToLow" <%= currentSort === 'highToLow' ? 'selected' : '' %>>High to Low</option>
                            <option value="lowToHigh" <%= currentSort === 'lowToHigh' ? 'selected' : '' %>>Low to High</option>
                        </select>
                    </div>
                </div>

                <div class="products-grid">
                    <% if (typeof products !== 'undefined' && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <% const variant = product.displayVariant; %>
                            <div class="product-card">
                                
                                <a href="/products/<%= product._id %>" style="display: block;">
                                    <div class="product-image">
                                        <img src="<%= product.images && product.images[0] ? product.images[0] : 'https://placehold.co/400' %>" alt="<%= product.name %>">
                                        <div class="badge-container">
                                            <% if (variant.discount > 0) { %>
                                                <span class="badge discount"><%= variant.discount %>% OFF</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </a>

                                <div class="product-info">
                                    <h3>
                                        <a href="/products/<%= product._id %>" style="color: inherit;">
                                            <%= product.name %> (<%= variant.variantName %>)
                                        </a>
                                    </h3>
                                    
                                    <div class="stars"><i class="fa-solid fa-star"></i> 4.8 (150)</div>
                                    
                                    <% 
                                        const variantIdStr = variant._id.toString(); 
                                        const isInWishlist = typeof userWishlist !== 'undefined' && userWishlist.includes(variantIdStr); 
                                    %>
                                    <button class="wishlist-btn <%= isInWishlist ? 'liked' : '' %>" type="button" data-variant-id="<%= variantIdStr %>">
                                        <i class="<%= isInWishlist ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
                                    </button>

                                    <div class="card-footer">
                                        <p class="price">
                                            <% if (variant.discount > 0) { %>
                                                <span class="old-price">₹<%= variant.originalPrice.toLocaleString('en-IN') %></span>
                                            <% } %>
                                            ₹<%= variant.calculatedPrice.toLocaleString('en-IN') %>
                                        </p>
                                        <button class="add-to-cart-btn" type="button" data-variant-id="<%= variantIdStr %>">
                                            <i class="fa-solid fa-cart-plus"></i> Add
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="fallback-notice-text">
                            <p>No mattresses found matching your selection criteria.</p>
                        </div>
                    <% } %>
                </div>

                <% if (totalPages > 1) { %>
                    <div class="pagination">
                        <% if (currentPage > 1) { %>
                            <button class="page-btn change-page-btn" data-page="<%= currentPage - 1 %>">
                                <i class="fa-solid fa-chevron-left"></i> Previous
                            </button>
                        <% } else { %>
                            <button class="page-btn disabled" disabled><i class="fa-solid fa-chevron-left"></i> Previous</button>
                        <% } %>

                        <div class="page-numbers">
                            <% for (let i = 1; i <= totalPages; i++) { %>
                                <button class="page-num change-page-btn <%= i === currentPage ? 'active' : '' %>" data-page="<%= i %>">
                                    <%= i %>
                                </button>
                            <% } %>
                        </div>

                        <% if (currentPage < totalPages) { %>
                            <button class="page-btn change-page-btn" data-page="<%= currentPage + 1 %>">
                                Next <i class="fa-solid fa-chevron-right"></i>
                            </button>
                        <% } else { %>
                            <button class="page-btn disabled" disabled>Next <i class="fa-solid fa-chevron-right"></i></button>
                        <% } %>
                    </div>
                <% } %>
            </section>
        </div>
    </main>

    <footer class="footer">
        <div class="container-fluid footer-container">
            <div class="footer-left">
                <a href="/home" class="logo footer-logo">HomeStation</a>
                <p>Your premier destination for high-quality mattresses and sleep essentials, crafted to bring cloud-like comfort to every night.</p>
            </div>
            <div class="footer-links-wrapper">
                <div class="footer-column">
                    <h4>Shop</h4>
                    <ul>
                        <li><a href="/products">World of Mattress</a></li>
                        <li><a href="/deals">Top Deals</a></li>
                        <li><a href="/bestsellers">Best Sellers</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="#">Track Your Orders</a></li>
                        <li><a href="/privacy-policy">Privacy Policy</a></li>
                        <li><a href="/contact">Contact Us</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="container-fluid copyright">
            <p>&copy; 2026 HomeStation Store. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/user/categories.js"></script>
</body>
</html>