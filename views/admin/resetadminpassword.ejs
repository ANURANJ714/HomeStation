<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation - ADMIN</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="icon" type="image/x-icon"
        href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <link rel="stylesheet" href="/css/admin/resetadminpassword.css">
</head>

<body class="admin-bg">
    <main class="login-container">
        <input type="hidden" id="csrfToken" value="<%= csrfToken %>">

        <div class="login-image-side">
            <div class="image-content">
                <h2 class="brand-title">HomeStation</h2>
                <span class="admin-badge">Admin Portal</span>
            </div>
        </div>

        <div class="login-form-side">
            <div class="form-wrapper">
                <h1 class="title">Create New Password</h1>
                <p class="subtitle">Create a new strong password.</p>

                <form id="resetPasswordForm" class="login-form">

                    <div class="form-group">

                        <label for="newPassword">
                            New Password
                        </label>

                        <div class="input-container password-container">
                            <i class="fa-solid fa-lock input-icon"></i>
                            <input type="password" id="newPassword" placeholder="Enter new password"
                                autocomplete="new-password">
                            <button type="button" class="toggle-password-btn" data-target="newPassword"
                                aria-label="Toggle password visibility">
                                <i class="fa-regular fa-eye-slash toggle-password"></i>
                            </button>
                        </div>
                    </div>

                    <div class="form-group confirm-password-group">
                        <label for="confirmPassword">
                            Confirm New Password
                        </label>
                        <div class="input-container password-container">
                            <i class="fa-solid fa-lock input-icon"></i>
                            <input type="password" id="confirmPassword" placeholder="Confirm new password"
                                autocomplete="new-password">
                            <button type="button" class="toggle-password-btn" data-target="confirmPassword"
                                aria-label="Toggle password visibility">
                                <i class="fa-regular fa-eye-slash toggle-password"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" id="submitBtn" class="btn btn-login">Update Password</button>

                </form>
            </div>
        </div>

    </main>

    <script src="/js/admin/resetadminpassword.js"></script>
</body>

</html>