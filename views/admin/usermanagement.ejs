<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation - ADMIN</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/css/admin/usermanagement.css">
</head>

<body>
    <div class="dashboard-layout">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-header">
                <h2 class="brand-title">HomeStation</h2>
                <button id="closeSidebar" class="close-sidebar-btn"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <nav class="sidebar-nav">
                <ul class="nav-list">
                    <li class="nav-item"><a href="/admin/dashboard" class="nav-link"><i class="fa-solid fa-chart-pie nav-icon"></i> Dashboard</a></li>
                    <li class="nav-item"><a href="/admin/products" class="nav-link"><i class="fa-solid fa-box nav-icon"></i> Products</a></li>
                    <li class="nav-item"><a href="/admin/categories" class="nav-link"><i class="fa-solid fa-tags nav-icon"></i> Categories</a></li>
                    <li class="nav-item"><a href="#" class="nav-link"><i class="fa-solid fa-cart-shopping nav-icon"></i> Orders</a></li>
                    <li class="nav-item"><a href="/admin/users" class="nav-link active"><i class="fa-solid fa-users nav-icon"></i> User Management</a></li>
                    <li class="nav-item"><a href="#" class="nav-link"><i class="fa-solid fa-file-invoice-dollar nav-icon"></i> Sales Report</a></li>
                    <li class="nav-item"><a href="#" class="nav-link"><i class="fa-solid fa-ticket nav-icon"></i> Manage Coupons</a></li>
                    <li class="nav-item"><a href="/admin/offers" class="nav-link"><i class="fa-solid fa-percent nav-icon"></i> Offers</a></li>
                    <li class="nav-item"><a href="/admin/enquiries" class="nav-link"><i class="fa-solid fa-envelope nav-icon"></i> Enquiry</a></li>
                </ul>

                <ul class="nav-list logout-section">
                    <li class="nav-item">
                        <form action="/admin/logout" method="POST" id="adminLogoutForm" class="m-0">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="logout-link logout-btn-submit" id="logoutButton">
                                <i class="fa-solid fa-right-from-bracket nav-icon"></i> Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </aside>

        <div class="main-panel">
            <header class="top-header">
                <div class="header-left">
                    <button id="hamburgerBtn" class="hamburger-btn">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                </div>
                <div class="header-right">
                    <div class="datetime-display" id="datetimeDisplay"></div>
                    <div class="notification-wrapper">
                        <i class="fa-regular fa-bell notification-bell"></i>
                    </div>
                    <div class="admin-badge">
                        <i class="fa-solid fa-user-shield"></i> Admin
                    </div>
                </div>
            </header>

            <main class="content-wrapper">
                <input type="hidden" id="csrfToken" value="<%= csrfToken %>">
                <div class="page-header-row">
                    <h1 class="page-title">User Management</h1>
                    <button class="btn btn-primary" id="openAddUserModal">
                        <i class="fa-solid fa-plus"></i> Add User
                    </button>
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon total-users-icon"><i class="fa-solid fa-users"></i></div>
                        <div class="stat-details">
                            <p class="stat-label">Total Users</p>
                            <h3 class="stat-value" id="totalUsersCount">
                                <%= stats ? stats.totalUsers : 0 %>
                            </h3>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon active-users-icon"><i class="fa-solid fa-user-check"></i></div>
                        <div class="stat-details">
                            <p class="stat-label">Active Users</p>
                            <h3 class="stat-value" id="activeUsersCount">
                                <%= stats ? stats.activeUsers : 0 %>
                            </h3>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon blocked-users-icon"><i class="fa-solid fa-user-lock"></i></div>
                        <div class="stat-details">
                            <p class="stat-label">Blocked Users</p>
                            <h3 class="stat-value" id="blockedUsersCount">
                                <%= stats ? stats.blockedUsers : 0 %>
                            </h3>
                        </div>
                    </div>
                </div>

                <form action="/admin/users" method="GET" class="filters-container" id="userFilterForm">
                    <div class="search-container-box">
                        <div class="search-box">
                            <i class="fa-solid fa-magnifying-glass search-icon"></i>
                            <input type="text" name="search"
                                value="<%= typeof filters !== 'undefined' ? filters.search : '' %>"
                                placeholder="Search by Name or Email...">
                        </div>
                        <button type="submit" class="btn btn-primary">Search</button>
                        <% if(typeof filters !== 'undefined' && (filters.search || filters.role || filters.status || filters.sort !== 'newest')) { %>
                            <a href="/admin/users" class="btn btn-secondary text-decoration-none">Clear</a>
                        <% } %>
                    </div>

                    <div class="filter-dropdowns">
                        <select name="role" class="filter-select" id="roleFilter">
                            <option value="" <%= typeof filters !== 'undefined' && filters.role === '' ? 'selected' : '' %>>All Roles</option>
                            <option value="user" <%= typeof filters !== 'undefined' && filters.role === 'user' ? 'selected' : '' %>>User</option>
                            <option value="admin" <%= typeof filters !== 'undefined' && filters.role === 'admin' ? 'selected' : '' %>>Admin</option>
                        </select>

                        <select name="status" class="filter-select" id="statusFilter">
                            <option value="" <%= typeof filters !== 'undefined' && filters.status === '' ? 'selected' : '' %>>All Status</option>
                            <option value="active" <%= typeof filters !== 'undefined' && filters.status === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="blocked" <%= typeof filters !== 'undefined' && filters.status === 'blocked' ? 'selected' : '' %>>Blocked</option>
                        </select>

                        <select name="sort" class="filter-select" id="sortFilter">
                            <option value="newest" <%= typeof filters !== 'undefined' && filters.sort === 'newest' ? 'selected' : '' %>>Sort by: Newest</option>
                            <option value="oldest" <%= typeof filters !== 'undefined' && filters.sort === 'oldest' ? 'selected' : '' %>>Sort by: Oldest</option>
                            <option value="az" <%= typeof filters !== 'undefined' && filters.sort === 'az' ? 'selected' : '' %>>Sort by: A - Z</option>
                            <option value="za" <%= typeof filters !== 'undefined' && filters.sort === 'za' ? 'selected' : '' %>>Sort by: Z - A</option>
                        </select>
                    </div>
                </form>

                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>User ID</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Orders</th>
                                <th>Total Spent</th>
                                <th>Status</th>
                                <th>Created Date</th>
                                <th class="actions-header">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof users !== 'undefined' && users.length > 0) { %>
                                <% users.forEach(user => { %>
                                    <tr id="user-row-<%= user._id %>" class="<%= user.status && user.status.toLowerCase() === 'blocked' ? 'blocked-row' : '' %>">
                                        <td>
                                            <div class="user-profile">
                                                <img src="<%= user.profileImage || 'https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y' %>" alt="Avatar" class="avatar">
                                                <span class="fw-500 <%= user.status && user.status.toLowerCase() === 'blocked' ? 'text-muted' : '' %>">
                                                    <%= user.fullName %>
                                                </span>
                                            </div>
                                        </td>
                                        <td class="text-muted">
                                            <%= user.userId || 'N/A' %>
                                        </td>
                                        <td class="<%= user.status && user.status.toLowerCase() === 'blocked' ? 'text-muted' : '' %>">
                                            <%= user.email %>
                                        </td>
                                        <td>
                                            <% let displayRole = 'User'; let isAdmin = false; if (user.role && typeof user.role === 'string') { displayRole = user.role.charAt(0).toUpperCase() + user.role.slice(1).toLowerCase(); if (displayRole === 'Admin') isAdmin = true; } %>
                                            <% if (isAdmin) { %>
                                                <span class="badge badge-admin-role">Admin</span>
                                            <% } else { %>
                                                <span class="badge badge-info">
                                                    <%= displayRole %>
                                                </span>
                                            <% } %>
                                        </td>
                                        <td>-</td>
                                        <td class="fw-500 <%= user.status && user.status.toLowerCase() === 'blocked' ? 'text-muted' : '' %>">-</td>
                                        <td class="status-cell">
                                            <% if (user.status && user.status.toLowerCase() === 'active') { %>
                                                <span class="badge badge-success">Active</span>
                                            <% } else { %>
                                                <span class="badge badge-danger">Blocked</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <%= new Date(user.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                        </td>
                                        <td class="actions-td">
                                            <% if (user.role === 'Admin') { %>
                                                <span class="text-muted italic-no-actions">No actions</span>
                                            <% } else if (user.status === 'Active' || user.status === 'active') { %>
                                                <button class="btn-action btn-block action-status" data-id="<%= user._id %>" data-action="Block">
                                                    <i class="fa-solid fa-ban"></i> Block
                                                </button>
                                            <% } else { %>
                                                <button class="btn-action btn-unblock action-status" data-id="<%= user._id %>" data-action="Unblock">
                                                    <i class="fa-solid fa-unlock"></i> Unblock
                                                </button>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="9" class="empty-users-cell">
                                        <i class="fa-solid fa-users-slash empty-users-icon"></i>
                                        <p class="empty-users-text">No users found matching your search or filters.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <% if (typeof pagination !== 'undefined' && pagination.totalPages > 0) { %>
                    <% let queryString = `&search=${filters.search || ''}&role=${filters.role || ''}&status=${filters.status || ''}&sort=${filters.sort || ''}`; %>
                    <div class="pagination-container">
                        <span class="pagination-info">
                            Showing <%= ((pagination.page - 1) * pagination.limit) + 1 %> to <%= Math.min(pagination.page * pagination.limit, pagination.totalFiltered) %> of <%= pagination.totalFiltered %> entries
                        </span>
                        <div class="pagination-controls">
                            <a href="<%= pagination.page > 1 ? `?page=${pagination.page - 1}${queryString}` : '#' %>" class="page-btn text-decoration-none <%= pagination.page === 1 ? 'disabled' : '' %>">
                                <i class="fa-solid fa-chevron-left"></i>
                            </a>
                            <% for(let i=1; i <= pagination.totalPages; i++) { %>
                                <a href="?page=<%= i %><%= queryString %>" class="page-btn text-decoration-none <%= pagination.page === i ? 'active' : '' %>">
                                    <%= i %>
                                </a>
                            <% } %>
                            <a href="<%= pagination.page < pagination.totalPages ? `?page=${pagination.page + 1}${queryString}` : '#' %>" class="page-btn text-decoration-none <%= pagination.page === pagination.totalPages ? 'disabled' : '' %>">
                                <i class="fa-solid fa-chevron-right"></i>
                            </a>
                        </div>
                    </div>
                <% } %>
            </main>
        </div>
    </div>

    <div id="addUserModal" class="modal-overlay">
        <div class="modal-content modal-box-max">
            <div class="modal-header-wrapper">
                <h2 class="modal-header-title">Add New User</h2>
                <i class="fa-solid fa-times modal-close-x" data-close="addUserModal"></i>
            </div>
            <form id="addUserForm">
                <div class="modal-form-group">
                    <label class="modal-form-label">Full Name</label>
                    <input type="text" id="addFullName" name="fullName" placeholder="Enter full name" class="modal-form-input">
                </div>
                <div class="modal-form-group">
                    <label class="modal-form-label">Email Address</label>
                    <input type="email" id="addEmail" name="email" placeholder="Enter email address" class="modal-form-input">
                </div>
                <div class="modal-form-group">
                    <label class="modal-form-label">Phone Number</label>
                    <input type="text" id="addPhone" name="phone" placeholder="10-digit phone number" class="modal-form-input">
                </div>
                <div class="modal-form-group">
                    <label class="modal-form-label">Password</label>
                    <div class="password-input-relative">
                        <input type="password" id="addPassword" name="password" placeholder="Create a strong password" class="modal-form-input pr-40">
                        <i class="fa-solid fa-eye-slash toggle-password" data-target="addPassword"></i>
                    </div>
                </div>
                <div class="modal-form-group mb-25">
                    <label class="modal-form-label">Confirm Password</label>
                    <div class="password-input-relative">
                        <input type="password" id="addConfirmPassword" name="confirmPassword" placeholder="Confirm password" class="modal-form-input pr-40">
                        <i class="fa-solid fa-eye-slash toggle-password" data-target="addConfirmPassword"></i>
                    </div>
                </div>
                <div class="modal-actions-flex">
                    <button type="button" class="btn btn-secondary" data-close="addUserModal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create User</button>
                </div>
            </form>
        </div>
    </div>

    <div id="blockUserModal" class="modal-overlay">
        <div class="modal-content modal-confirmation-box">
            <i class="fa-solid fa-ban modal-icon-block"></i>
            <h2 class="modal-confirmation-title">Block User</h2>
            <p class="modal-confirmation-desc">Are you sure you want to block this user? They will not be able to log in.</p>
            <div>
                <button class="btn btn-secondary mr-10" data-close="blockUserModal">Cancel</button>
                <button class="btn btn-primary btn-bg-danger" id="confirmBlockBtn">Confirm Block</button>
            </div>
        </div>
    </div>

    <div id="unblockUserModal" class="modal-overlay">
        <div class="modal-content modal-confirmation-box">
            <i class="fa-solid fa-unlock modal-icon-unblock"></i>
            <h2 class="modal-confirmation-title">Unblock User</h2>
            <p class="modal-confirmation-desc">Are you sure you want to unblock this user? Their access will be restored.</p>
            <div>
                <button class="btn btn-secondary mr-10" data-close="unblockUserModal">Cancel</button>
                <button class="btn btn-primary btn-bg-success" id="confirmUnblockBtn">Confirm Unblock</button>
            </div>
        </div>
    </div>

    <script src="/js/admin/usermanagement.js"></script>
</body>

</html>