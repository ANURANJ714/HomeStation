<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation - ADMIN</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin/viewcategoryproducts.css">
</head>

<body>
    <div class="dashboard-layout">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-header">
                <h2 class="brand-title">HomeStation</h2>
                <button class="close-sidebar" id="closeSidebar"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <nav class="sidebar-nav">
                <ul class="nav-list">
                    <li class="nav-item"><a href="/admin/dashboard" class="nav-link"><i class="fa-solid fa-chart-pie nav-icon"></i> Dashboard</a></li>
                    <li class="nav-item"><a href="/admin/products" class="nav-link"><i class="fa-solid fa-box nav-icon"></i> Products</a></li>
                    <li class="nav-item"><a href="/admin/categories" class="nav-link active"><i class="fa-solid fa-tags nav-icon"></i> Categories</a></li>
                    <li class="nav-item"><a href="#" class="nav-link"><i class="fa-solid fa-cart-shopping nav-icon"></i> Orders</a></li>
                    <li class="nav-item"><a href="/admin/users" class="nav-link"><i class="fa-solid fa-users nav-icon"></i> User Management</a></li>
                    <li class="nav-item"><a href="#" class="nav-link"><i class="fa-solid fa-file-invoice-dollar nav-icon"></i> Sales Report</a></li>
                    <li class="nav-item"><a href="#" class="nav-link"><i class="fa-solid fa-ticket nav-icon"></i> Manage Coupons</a></li>
                    <li class="nav-item"><a href="/admin/offers" class="nav-link"><i class="fa-solid fa-percent nav-icon"></i> Offers</a></li>
                    <li class="nav-item"><a href="#" class="nav-link"><i class="fa-solid fa-envelope nav-icon"></i> Enquiry</a></li>
                </ul>
                <ul class="nav-list logout-section">
                    <li class="nav-item">
                        <form action="/admin/logout" method="POST" class="m-0">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="logout-link logout-btn-submit">
                                <i class="fa-solid fa-right-from-bracket nav-icon"></i> Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </aside>

        <div class="main-panel">
            <header class="top-header">
                <div class="header-left">
                    <button class="hamburger-menu" id="hamburgerMenu">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                </div>
                <div class="header-right">
                    <div class="datetime-display" id="datetimeDisplay"></div>
                    <div class="notification-wrapper">
                        <i class="fa-regular fa-bell notification-bell"></i>
                    </div>
                    <div class="admin-badge"><i class="fa-solid fa-user-shield"></i> Admin</div>
                </div>
            </header>

            <main class="content-wrapper">
                <input type="hidden" id="categoryIdHidden" value="<%= categoryId %>">
                <input type="hidden" id="searchQueryHidden" value="<%= searchQuery %>">

                <div class="page-header-row mb-20">
                    <div class="header-left-title">
                        <a href="/admin/categories" class="back-link">
                            <i class="fa-solid fa-arrow-left"></i> Back to Categories
                        </a>
                        <h1 class="page-title"><%= categoryName %></h1>
                    </div>

                    <div class="header-actions-group">
                        <form action="/admin/categories/<%= categoryId %>/products" method="GET" class="search-form-container">
                            <input type="hidden" name="sort" value="<%= currentSort %>">
                            <i class="fa-solid fa-magnifying-glass search-form-icon"></i>
                            <input type="text" name="search" value="<%= searchQuery %>" placeholder="Search products..." class="search-form-input">
                            
                            <% if (searchQuery) { %>
                                <a href="/admin/categories/<%= categoryId %>/products?sort=<%= currentSort %>" class="search-form-clear"><i class="fa-solid fa-xmark"></i></a>
                            <% } else { %>
                                <button type="submit" class="search-form-submit">Search</button>
                            <% } %>
                        </form>

                        <div class="sort-wrap">
                            <label class="sort-label" for="sortSelect">Sort:</label>
                            <select id="sortSelect" class="sort-select">
                                <option value="newest" <%= currentSort === 'newest' ? 'selected' : '' %>>Newest</option>
                                <option value="oldest" <%= currentSort === 'oldest' ? 'selected' : '' %>>Oldest</option>
                                <option value="az" <%= currentSort === 'az' ? 'selected' : '' %>>Sort by: A–Z</option>
                                <option value="za" <%= currentSort === 'za' ? 'selected' : '' %>>Sort by: Z–A</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="table-card">
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="w-70">Image</th>
                                    <th>Product Name</th>
                                    <th>Price Range</th>
                                    <th>Total Stock</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (products && products.length > 0) { %>
                                    <% products.forEach(product => { %>
                                        <tr>
                                            <td>
                                                <img src="<%= product.images && product.images.length > 0 ? product.images[0] : 'https://placehold.co/80x80?text=No+Image' %>" 
                                                     alt="<%= product.name %>" class="product-thumb-sm"
                                                     onerror="this.onerror=null;this.src='https://placehold.co/80x80?text=No+Image';">
                                            </td>
                                            <td class="fw-500"><%= product.name %></td>
                                            <td><%= product.priceDisplay %></td>
                                            <td><span class="badge <%= product.badgeClass %>"><%= product.calculatedStock %></span></td>
                                            <td><span class="status-dot <%= product.dotClass %>"></span> <%= product.stockStatus %></td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <% if (!products || products.length === 0) { %>
                        <div class="empty-state show-flex">
                            <i class="fa-solid fa-box-open"></i>
                            <% if (searchQuery) { %>
                                <p>No products found matching "<%= searchQuery %>" in this category.</p>
                            <% } else { %>
                                <p>No products found in this category.</p>
                            <% } %>
                        </div>
                    <% } %>

                    <% if (totalProducts > 0) { %>
                        <div class="table-footer">
                            <% 
                                let startEntry = (currentPage - 1) * limit + 1; 
                                let endEntry = Math.min(currentPage * limit, totalProducts); 
                            %>
                            <span class="pagination-info">Showing <%= startEntry %>–<%= endEntry %> of <%= totalProducts %> products</span>
                            
                            <div class="pagination-controls">
                                <% if (currentPage > 1) { %>
                                    <a href="?search=<%= searchQuery %>&sort=<%= currentSort %>&page=<%= currentPage - 1 %>" class="page-btn"><i class="fa-solid fa-chevron-left"></i></a>
                                <% } else { %>
                                    <button class="page-btn disabled"><i class="fa-solid fa-chevron-left"></i></button>
                                <% } %>

                                <% for (let i = 1; i <= totalPages; i++) { %>
                                    <a href="?search=<%= searchQuery %>&sort=<%= currentSort %>&page=<%= i %>" class="page-btn <%= currentPage === i ? 'active' : '' %>"><%= i %></a>
                                <% } %>

                                <% if (currentPage < totalPages) { %>
                                    <a href="?search=<%= searchQuery %>&sort=<%= currentSort %>&page=<%= currentPage + 1 %>" class="page-btn"><i class="fa-solid fa-chevron-right"></i></a>
                                <% } else { %>
                                    <button class="page-btn disabled"><i class="fa-solid fa-chevron-right"></i></button>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>

    <script src="/js/admin/viewcategoryproducts.js"></script>
</body>

</html>