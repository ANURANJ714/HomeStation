<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation - ADMIN</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/x-icon"
        href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/css/admin/products.css">
</head>

<body>
    <div class="dashboard-layout">

        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-header">
                <h2 class="brand-title">HomeStation</h2>
                <button id="closeSidebar" class="close-sidebar-btn"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <nav class="sidebar-nav">
                <ul class="nav-list">
                    <li class="nav-item">
                        <a href="/admin/dashboard" class="nav-link">
                            <i class="fa-solid fa-chart-pie nav-icon"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/products" class="nav-link active">
                            <i class="fa-solid fa-box nav-icon"></i> Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/categories" class="nav-link">
                            <i class="fa-solid fa-tags nav-icon"></i> Categories
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="fa-solid fa-cart-shopping nav-icon"></i> Orders
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/users" class="nav-link">
                            <i class="fa-solid fa-users nav-icon"></i> User Management
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="fa-solid fa-file-invoice-dollar nav-icon"></i> Sales Report
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="fa-solid fa-ticket nav-icon"></i> Manage Coupons
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/offers" class="nav-link">
                            <i class="fa-solid fa-percent nav-icon"></i> Offers
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/enquiries" class="nav-link">
                            <i class="fa-solid fa-envelope nav-icon"></i> Enquiry
                        </a>
                    </li>
                </ul>

                <ul class="nav-list logout-section">
                    <li class="nav-item">
                        <form action="/admin/logout" method="POST" id="adminLogoutForm" class="m-0">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="nav-link logout-link logout-btn-submit">
                                <i class="fa-solid fa-right-from-bracket nav-icon"></i> Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </aside>

        <div class="main-panel">

            <header class="top-header">
                <div class="header-left">
                    <button id="hamburgerBtn" class="hamburger-btn">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                </div>
                <div class="header-right">
                    <div class="datetime-display" id="datetimeDisplay"></div>
                    <div class="notification-wrapper">
                        <i class="fa-regular fa-bell notification-bell"></i>
                    </div>
                    <div class="admin-badge">
                        <i class="fa-solid fa-user-shield"></i> Admin
                    </div>
                </div>
            </header>

            <main class="content-wrapper">
                <input type="hidden" id="csrfToken" value="<%= csrfToken %>">

                <div class="page-header-row right-aligned-header">
                    <h1 class="page-title">Products</h1>

                    <div class="header-actions">
                        <a href="/admin/products/deleted" class="btn btn-outline-danger">
                            <i class="fa-solid fa-trash-can"></i> Recycle Bin
                        </a>
                        <a href="/admin/products/add" class="btn btn-primary">
                            <i class="fa-solid fa-plus"></i> Add New Product
                        </a>
                    </div>
                </div>

                <form action="/admin/products" method="GET" class="filters-container">

                    <div class="search-box-wrapper">
                        <i class="fa-solid fa-magnifying-glass search-icon"></i>
                        <input type="text" name="search"
                            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
                            placeholder="Search products..." class="search-input">

                        <% if (typeof searchQuery !=='undefined' && searchQuery) { %>
                            <a href="/admin/products?status=<%= typeof statusFilter !== 'undefined' ? statusFilter : 'all' %>"
                                class="search-clear-btn"><i class="fa-solid fa-xmark"></i></a>
                            <% } else { %>
                                <button type="submit" class="search-submit-btn">Search</button>
                                <% } %>
                    </div>

                    <div class="filter-dropdowns">
                        <label class="filter-label">Filter:</label>

                        <select class="filter-select" name="status" id="statusFilter">
                            <option value="all" <%=typeof statusFilter !=='undefined' && statusFilter==='all'
                                ? 'selected' : '' %>>All Status</option>
                            <option value="instock" <%=typeof statusFilter !=='undefined' && statusFilter==='instock'
                                ? 'selected' : '' %>>In Stock</option>
                            <option value="lowstock" <%=typeof statusFilter !=='undefined' && statusFilter==='lowstock'
                                ? 'selected' : '' %>>Low Stock</option>
                            <option value="outstock" <%=typeof statusFilter !=='undefined' && statusFilter==='outstock'
                                ? 'selected' : '' %>>Out of Stock</option>
                        </select>

                        <button type="submit" class="d-none"></button>
                    </div>
                </form>

                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th class="w-90">Image</th>
                                <th class="product-name-col">Product Name</th>
                                <th>Product ID</th>
                                <th>Price Range</th>
                                <th>Total Stock</th>
                                <th>Status</th>
                                <th class="actions-header">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (products && products.length> 0) { %>
                                <% products.forEach(product=> { %>
                                    <tr>
                                        <td>
                                            <img src="<%= product.images && product.images.length > 0 ? product.images[0] : 'https://placehold.co/60x60?text=No+Image' %>"
                                                alt="<%= product.name %>" class="product-thumb"
                                                onerror="this.onerror=null;this.src='https://placehold.co/60x60?text=No+Image';">
                                        </td>
                                        <td class="fw-500 product-name-col">
                                            <%= product.name %>
                                        </td>
                                        <td class="fw-500 text-muted">
                                            <%= product.productId || 'No SKU' %>
                                        </td>

                                        <td class="fw-700">
                                            <%= product.priceDisplay %>
                                        </td>
                                        <td class="fw-500">
                                            <%= product.calculatedStock %>
                                        </td>
                                        <td>
                                            <span class="badge <%= product.badgeClass %>">
                                                <%= product.stockStatus %>
                                            </span>
                                        </td>

                                        <td class="actions-td">
                                            <div class="actions-cell">
                                                <a href="/admin/products/<%= product.productId %>"
                                                    class="btn-icon view">
                                                    <i class="fa-regular fa-eye"></i>
                                                </a>
                                                <a href="/admin/products/<%= product.productId %>/edit"
                                                    class="btn-icon edit">
                                                    <i class="fa-solid fa-pen-to-square"></i>
                                                </a>

                                                <button class="btn-icon delete" data-id="<%= product._id %>"
                                                    data-name="<%= encodeURIComponent(product.name) %>">
                                                    <i class="fa-regular fa-trash-can"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="7" class="empty-table-cell">
                                                    <i class="fa-solid fa-box-open empty-table-icon"></i>
                                                    <% if (typeof searchQuery !=='undefined' && searchQuery) { %>
                                                        No products found matching "<%= searchQuery %>".
                                                            <% } else { %>
                                                                No products found for the selected filters.
                                                                <% } %>
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>

                <div class="pagination-container">
                    <% let startEntry=(currentPage - 1) * limit + 1; let endEntry=Math.min(currentPage * limit,
                        totalProducts); if (totalProducts===0) { startEntry=0; endEntry=0; } let queryParams='?' ; if
                        (typeof searchQuery !=='undefined' && searchQuery) queryParams +=`search=${searchQuery}&`; if
                        (typeof statusFilter !=='undefined' && statusFilter) queryParams +=`status=${statusFilter}&`;
                        queryParams +='page=' ; %>
                        <span class="pagination-info">Showing <%= startEntry %> to <%= endEntry %> of <%= totalProducts
                                        %> entries</span>

                        <div class="pagination-controls">
                            <% if (currentPage> 1) { %>
                                <a href="<%= queryParams %><%= currentPage - 1 %>"
                                    class="page-btn text-decoration-none">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </a>
                                <% } else { %>
                                    <button class="page-btn disabled"><i class="fa-solid fa-chevron-left"></i></button>
                                    <% } %>

                                        <% for (let i=1; i <=totalPages; i++) { %>
                                            <% if (i===currentPage) { %>
                                                <button class="page-btn active">
                                                    <%= i %>
                                                </button>
                                                <% } else { %>
                                                    <a href="<%= queryParams %><%= i %>"
                                                        class="page-btn text-decoration-none">
                                                        <%= i %>
                                                    </a>
                                                    <% } %>
                                                        <% } %>

                                                            <% if (currentPage < totalPages) { %>
                                                                <a href="<%= queryParams %><%= currentPage + 1 %>"
                                                                    class="page-btn text-decoration-none">
                                                                    <i class="fa-solid fa-chevron-right"></i>
                                                                </a>
                                                                <% } else { %>
                                                                    <button class="page-btn disabled"><i
                                                                            class="fa-solid fa-chevron-right"></i></button>
                                                                    <% } %>
                        </div>
                </div>

            </main>
        </div>
    </div>

    <div class="modal-overlay" id="deleteProductModal">
        <div class="modal-content max-w-400 text-center">
            <div class="modal-body pt-30">
                <i class="fa-regular fa-trash-can modal-trash-icon"></i>
                <h3 class="mb-10">Delete Product</h3>
                <p id="deleteMessage" class="modal-desc-text">Are you sure?</p>
                <div class="modal-btn-group">
                    <button type="button" class="btn btn-secondary" id="cancelDeleteBtn">Cancel</button>
                    <button type="button" id="confirmDeleteBtn" class="btn btn-danger">Delete</button>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/admin/products.js"></script>
</body>

</html>