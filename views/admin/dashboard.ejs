<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeStation - ADMIN</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/x-icon"
        href="https://res.cloudinary.com/dz7fuqwnr/image/upload/v1778395481/WhatsApp_Image_2026-05-10_at_12.12.36_nra5vk.jpg">
    <link rel="stylesheet" href="/css/admin/dashboard.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
    <div class="dashboard-layout">

        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-header sidebar-header-flex">
                <h2 class="brand-title">HomeStation</h2>
                <button id="closeSidebar" class="close-sidebar-btn"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <nav class="sidebar-nav">
                <ul class="nav-list">
                    <li class="nav-item">
                        <a href="/admin/dashboard" class="nav-link active">
                            <i class="fa-solid fa-chart-pie nav-icon"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/products" class="nav-link">
                            <i class="fa-solid fa-box nav-icon"></i> Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/categories" class="nav-link">
                            <i class="fa-solid fa-tags nav-icon"></i> Categories
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="fa-solid fa-cart-shopping nav-icon"></i> Orders
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/users" class="nav-link">
                            <i class="fa-solid fa-users nav-icon"></i> User Management
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="fa-solid fa-file-invoice-dollar nav-icon"></i> Sales Report
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="fa-solid fa-ticket nav-icon"></i> Manage Coupons
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/offers" class="nav-link">
                            <i class="fa-solid fa-percent nav-icon"></i> Offers
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="fa-solid fa-envelope nav-icon"></i> Enquiry
                        </a>
                    </li>
                </ul>

                <ul class="nav-list logout-section">
                    <li class="nav-item">
                        <form action="/admin/logout" method="POST" id="adminLogoutForm" class="logout-form">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="logout-link logout-btn">
                                <i class="fa-solid fa-right-from-bracket nav-icon"></i> Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </aside>

        <div class="main-panel">
            <header class="top-header">
                <div class="header-left">
                    <button id="hamburgerBtn" class="hamburger-btn">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                </div>
                <div class="header-right">
                    <div class="datetime-display" id="datetimeDisplay"></div>
                    <div class="notification-wrapper">
                        <i class="fa-regular fa-bell notification-bell"></i>
                    </div>
                    <div class="admin-badge">
                        <i class="fa-solid fa-user-shield"></i> Admin
                    </div>
                </div>
            </header>

            <main class="content-wrapper">
                <input type="hidden" id="csrfToken" value="<%= csrfToken %>">

                <div class="page-header-row page-header-spacing flex-end-row">
                    <button class="btn btn-primary" id="openBannerModalBtn">Banner Details</button>
                </div>

                <h2 class="stats-heading">Lifetime Statistics</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon total-revenue-icon"><i class="fa-solid fa-wallet"></i></div>
                        <div class="stat-details">
                            <p class="stat-label">Total Revenue</p>
                            <h3 class="stat-value">₹54,20,000</h3>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon total-items-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
                        <div class="stat-details">
                            <p class="stat-label">Total Items Sold</p>
                            <h3 class="stat-value">3,842</h3>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon total-users-icon"><i class="fa-solid fa-users-viewfinder"></i></div>
                        <div class="stat-details">
                            <p class="stat-label">Total Users</p>
                            <h3 class="stat-value">1,248</h3>
                        </div>
                    </div>
                </div>

                <h2 class="stats-heading">Last 30 Days</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon revenue-icon"><i class="fa-solid fa-indian-rupee-sign"></i></div>
                        <div class="stat-details">
                            <p class="stat-label">Revenue</p>
                            <h3 class="stat-value">₹4,25,000</h3>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon items-icon"><i class="fa-solid fa-couch"></i></div>
                        <div class="stat-details">
                            <p class="stat-label">Items Sold</p>
                            <h3 class="stat-value">342</h3>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon users-icon"><i class="fa-solid fa-user-plus"></i></div>
                        <div class="stat-details">
                            <p class="stat-label">New Users</p>
                            <h3 class="stat-value">128</h3>
                        </div>
                    </div>
                </div>

                <div class="performance-section">
                    <h2 class="section-title">Category Performance</h2>
                    <div class="category-list">
                        <div class="category-item">
                            <div class="cat-info">
                                <span class="cat-name">Spring Mattress</span>
                                <span class="cat-sales">45% of total sales</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill progress-green" data-width="45"></div>
                            </div>
                        </div>
                        <div class="category-item">
                            <div class="cat-info">
                                <span class="cat-name">Coir Mattress</span>
                                <span class="cat-sales">25% of total sales</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill progress-blue" data-width="25"></div>
                            </div>
                        </div>
                        <div class="category-item">
                            <div class="cat-info">
                                <span class="cat-name">Orthopedic Mattress</span>
                                <span class="cat-sales">18% of total sales</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill progress-orange" data-width="18"></div>
                            </div>
                        </div>
                        <div class="category-item">
                            <div class="cat-info">
                                <span class="cat-name">Pillows</span>
                                <span class="cat-sales">12% of total sales</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill progress-purple" data-width="12"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <div class="modal-overlay" id="bannerDetailsModal">
        <div class="modal-content banner-modal-content">
            <div class="modal-header">
                <h2>Banner Details</h2>
                <button type="button" class="close-modal-btn" data-close="bannerDetailsModal"><i
                        class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <form id="bannerDetailsForm">
                    <div class="form-group">
                        <label>Banner Text</label>
                        <textarea id="bannerText" rows="3" class="banner-textarea"
                            placeholder="Enter banner text or leave blank to clear..."><%= typeof bannerText !== 'undefined' ? bannerText : '' %></textarea>
                    </div>
                    <div class="modal-footer banner-modal-footer">
                        <button type="button" class="btn btn-secondary" data-close="bannerDetailsModal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="saveBannerBtn">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="/js/admin/dashboard.js" defer></script>
</body>

</html>